{
  "name": "daily-content",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cf:dev": "npm run build && wrangler pages dev dist",
    "cf:deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply daily-content-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply daily-content-db --remote",
    "generate:daily": "tsx scripts/generate-daily.ts",
    "modes:sync": "tsx scripts/sync-modes.ts",
    "vapid:generate": "web-push generate-vapid-keys --json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "web-push": "^3.6.7",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251208.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wrangler": "^4.92.0"
  }
}

