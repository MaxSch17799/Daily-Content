# Local-only helper values. Do not commit a real .env file.

# OpenAI
OPENAI_API_KEY=

# Cloudflare API for GitHub Actions / local generator
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=c57001e6-7d81-420f-b8b1-1f4266cb4e74

# R2 S3-compatible upload credentials for the generator
R2_BUCKET_NAME=images
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public URL of the deployed Cloudflare Pages site, for notification links.
PUBLIC_SITE_URL=https://daily-content.pages.dev

# Web Push VAPID keys. Generate with: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=you@example.com

# Passwords
VIEWER_PASSWORD=
SUBSCRIBE_PASSWORD=
ADMIN_PASSWORD=

# Optional behavior
APP_TIMEZONE=Europe/Berlin
DEFAULT_MODE=fictional_satire_news
DEFAULT_LANGUAGE=en
FORCE_GENERATE=false
